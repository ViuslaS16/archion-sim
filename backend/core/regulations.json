  "compliance_scoring": {
    "critical_violations": {
      "weight": 10,
      "examples": [
        "corridor_width_below_minimum",
        "ramp_gradient_excessive",
        "emergency_exit_blocked",
        "fire_safety_non_compliant"
      ]
    },
    "high_violations": {
      "weight": 5,
      "examples": [
        "door_width_insufficient",
        "turning_space_inadequate",
        "handrail_missing",
        "signage_inadequate"
      ]
    },
    "medium_violations": {
      "weight": 2,
      "examples": [
        "bottleneck_temporary",
        "lighting_insufficient",
        "ventilation_suboptimal"
      ]
    },
    "low_violations": {
      "weight": 1,
      "examples": [
        "finish_quality",
        "aesthetic_concerns",
        "minor_dimension_variance"
      ]
    },
    "pass_threshold_percent": 80.0,
    "excellent_threshold_percent": 95.0
